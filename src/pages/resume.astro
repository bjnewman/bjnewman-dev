---
import InteriorBase from '../layouts/InteriorBase.astro';
import { RPGPanel } from '../components/Interior/RPGPanel';
import { ResumeTimeline } from '../components/ResumeTimeline';
import { SkillsGrid } from '../components/SkillsGrid';
import { EducationCards } from '../components/EducationCards';
import { PageCollectible } from '../components/ScavengerHunt';
import '../styles/resume-timeline.css';
---

<InteriorBase title="Courthouse" buildingId="courthouse">
  <RPGPanel>
    <div class="resume-header">
      <h2>Resume</h2>
      <a href="/resume.md" download class="resume-download" aria-label="Download full resume as markdown">
        <span class="resume-download__icon">↓</span>
        <span class="resume-download__text">Full Resume</span>
      </a>
    </div>
  </RPGPanel>

  <RPGPanel>
    <h2>Experience</h2>
    <ResumeTimeline client:visible />
  </RPGPanel>

  <RPGPanel>
    <h2>Skills <PageCollectible id="rare_gem" client:visible /></h2>
    <SkillsGrid client:visible />
  </RPGPanel>

  <RPGPanel>
    <h2>Education</h2>
    <EducationCards client:visible />
  </RPGPanel>
</InteriorBase>
