---
import { ViewTransitions } from 'astro:transitions';
import Overworld from '../components/Overworld';
import '../styles/theme.css';
import '../styles/overworld.css';
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8">
    <meta name="viewport" content="width=device-width,initial-scale=1">
    <title>Ben Newman</title>
    <meta name="description" content="Software engineer and technology enthusiast. Explore the village to navigate the site.">
    <link rel="canonical" href={new URL('/', Astro.site)}>
    <meta property="og:type" content="website">
    <meta property="og:title" content="Ben Newman">
    <meta property="og:site_name" content="Ben Newman">
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&family=JetBrains+Mono:wght@400;500&display=swap" rel="stylesheet">
    <link rel="alternate" type="application/rss+xml" title="Ben Newman's Blog" href="/rss.xml">
    <ViewTransitions />
  </head>
  <body class="overworld-page">
    <Overworld client:only="react" />
  </body>
</html>
