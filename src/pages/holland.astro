---
import InteriorBase from '../layouts/InteriorBase.astro';
import { RPGPanel } from '../components/Interior/RPGPanel';
---

<InteriorBase title="Treehouse" buildingId="fairy-treehouse">
  <RPGPanel variant="wood">
    <p class="holland-guard"><strong>HALT, TRAVELER!</strong> This page is for Holland and Holland ONLY. All unauthorized visitors must immediately close their eyes, spin around three times, and forget everything they saw. Violators will be turned into frogs.</p>
    <p class="holland-guard holland-guard--warning"><em>(You have been warned.)</em></p>
  </RPGPanel>

  <RPGPanel>
    <h2>Welcome Holland!</h2>
    <p>You found the secret page! This is your very own special corner of Uncle Ben's website.</p>
  </RPGPanel>

  <RPGPanel variant="wood">
    <h2>Cool Stuff</h2>
    <p>Here are some fun things you can do:</p>
    <ul>
      <li>Press <kbd>Cmd+K</kbd> (or <kbd>Ctrl+K</kbd>) anywhere on this site to open the secret menu</li>
      <li>Try the confetti button for a party!</li>
      <li>Change the colors with the switcher</li>
      <li>Turn on your favorite music</li>
    </ul>
  </RPGPanel>

  <RPGPanel>
    <h2>A Special Message</h2>
    <div class="holland-message">
      <p>Holland, you're my favorite! You are so brave and creative and curious. Keep exploring!</p>
      <p>Love, Uncle Ben</p>
    </div>
  </RPGPanel>

  <div class="holland-footer">
    <p>This page is top secret!</p>
  </div>
</InteriorBase>

<style>
.holland-message {
  background: linear-gradient(135deg, #d1b3ff, #e6d1ff);
  color: #2a1a0a;
  padding: 1.5rem;
  border-radius: 8px;
  text-align: center;
}

.holland-message p {
  color: #2a1a0a;
  font-size: 1.1rem;
  margin: 0.5rem 0;
}

.holland-guard {
  text-align: center;
  font-size: 1rem;
  color: #3a2a1a;
  margin: 0.5rem 0;
}

.holland-guard--warning {
  font-size: 0.9rem;
  color: #6a4a2a;
}

.holland-footer {
  text-align: center;
  margin-top: 1.5rem;
  color: #e0c97f;
  font-size: 1.1rem;
}
</style>
