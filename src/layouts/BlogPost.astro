---
import InteriorBase from './InteriorBase.astro';
import { RPGPanel } from '../components/Interior/RPGPanel';

interface Props {
  title: string;
  date: string;
  description?: string;
}

const { title, date, description } = Astro.props.frontmatter || Astro.props;

const formattedDate = new Date(date).toLocaleDateString('en-US', {
  year: 'numeric',
  month: 'long',
  day: 'numeric'
});
---

<InteriorBase title={title} buildingId="library" description={description}>
  <RPGPanel>
    <a href="/blog" class="back-link">&larr; Back to Library</a>

    <header class="blog-post-header">
      <h2>{title}</h2>
      <time datetime={date}>{formattedDate}</time>
    </header>

    <div class="blog-post-content">
      <slot />
    </div>
  </RPGPanel>
</InteriorBase>

<style>
  .back-link {
    display: inline-block;
    margin-bottom: 1.5rem;
    color: #6a3d0a;
    text-decoration: none;
    font-weight: 500;
  }

  .back-link:hover {
    text-decoration: underline;
  }

  .blog-post-header {
    margin-bottom: 1.5rem;
  }

  .blog-post-header h2 {
    margin: 0 0 0.5rem 0;
    font-size: 2rem;
    line-height: 1.2;
  }

  .blog-post-header time {
    color: #8b6d4c;
    font-size: 0.9rem;
  }

  .blog-post-content {
    line-height: 1.8;
  }

  .blog-post-content :global(h2) {
    margin-top: 2.5rem;
    margin-bottom: 1rem;
  }

  .blog-post-content :global(h3) {
    margin-top: 2rem;
    margin-bottom: 0.75rem;
  }

  .blog-post-content :global(pre) {
    margin: 1.5rem 0;
    padding: 1rem;
    border-radius: 4px;
    overflow-x: auto;
    background: #2a1a0a;
    color: #f5e6c8;
  }

  .blog-post-content :global(code) {
    font-family: 'JetBrains Mono', monospace;
    font-size: 0.9em;
  }

  .blog-post-content :global(ul),
  .blog-post-content :global(ol) {
    margin: 1rem 0;
    padding-left: 1.5rem;
  }

  .blog-post-content :global(li) {
    margin: 0.5rem 0;
  }

  .blog-post-content :global(blockquote) {
    margin: 1.5rem 0;
    padding: 1rem 1.5rem;
    border-left: 4px solid #c4a46a;
    background: rgba(196, 164, 106, 0.1);
    border-radius: 0 4px 4px 0;
  }

  .blog-post-content :global(a) {
    color: #6a3d0a;
  }
</style>
